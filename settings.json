{
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_METRICS_ENDPOINT": "https://app.jellyfish.co/ingest-webhooks/claude/2182",
    "OTEL_EXPORTER_OTLP_HEADERS": "Authorization=Bearer jf_xb-onYd_M7Zko6UVbZKLhGbbfZSb6OplHF-8gnz2AzE"
  },
  "permissions": {
    "allow": [
      "Edit(**)",
      "Write(**)",
      "MultiEdit(**)",
      "NotebookEdit(**)",
      "Bash(git status:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git -C:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(sleep:*)",
      "Bash(command -v codex:*)",
      "Bash(codex:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(CI=true npm test:*)",
      "Bash(CI=true npx react-scripts test:*)",
      "Bash(env CI=true npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npx firebase:*)",
      "Bash(firebase deploy:*)",
      "Bash(firebase emulators:start:*)",
      "Bash(playwright-cli:*)",
      "Bash(playwright-cli eval *)",
      "Bash(playwright-cli eval:*)",
      "Bash(playwright-cli run-code:*)",
      "Bash(npx playwright-cli:*)",
      "Bash(npx playwright-cli run-code:*)",
      "Bash(UNIQUE_EMAIL=:*)",
      "Bash(~/.claude/skills/combined-flow-retired-path/retired-flow.sh:*)",
      "Bash(/Users/fabianodesouza/.claude/skills/combined-flow-retired-path/retired-flow.sh:*)",
      "Bash(~/.claude/skills/combined-flow-retired-path/retired-flow-prequal-only.sh:*)",
      "Bash(/Users/fabianodesouza/.claude/skills/combined-flow-retired-path/retired-flow-prequal-only.sh:*)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "mcp__atlassian__search",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__editJiraIssue",
      "mcp__atlassian__getAccessibleAtlassianResources",
      "mcp__atlassian__fetch",
      "mcp__context7__*",
      "mcp__sequential-thinking__*"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + $timestamp + \"] \" + .tool_input.command + \" - \" + (.tool_input.description // \"No description\")' --arg timestamp \"$(date '+%Y-%m-%d %H:%M:%S')\" >> ~/.claude/bash-command-log.txt"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qiE 'firebase.*deploy'; then if ! echo \"$cmd\" | grep -qE '(--project[= ]+|-P\\s*)stage-trident'; then echo 'BLOCKED: Firebase deploy must explicitly target --project stage-trident. Production deploys require manual execution outside Claude Code.' >&2; exit 2; fi; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qE 'rm\\s+-[a-zA-Z]*r[a-zA-Z]*f|rm\\s+-[a-zA-Z]*f[a-zA-Z]*r|rm\\s+-r\\b|rm\\s+-[a-zA-Z]*r\\b.*\\*|find\\s.*-delete|xargs\\s+rm'; then echo 'BLOCKED: Mass delete operations (rm -rf, rm -r, find -delete, xargs rm) are not allowed. Remove files individually.' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qiE 'firebase\\s+(firestore:delete|firestore:databases:delete|database:remove|database:set|hosting:disable|hosting:channel:delete|functions:delete|functions:secrets:destroy|functions:secrets:prune|functions:config:unset|ext:uninstall|remoteconfig:rollback|remoteconfig:experiments:delete|remoteconfig:rollouts:delete|appdistribution:testers:remove|appdistribution:groups:delete|dataconnect:sql:migrate|dataconnect:sql:shell)'; then echo 'BLOCKED: Destructive Firebase CLI command detected. These operations must be run manually outside Claude Code.' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + $timestamp + \"] Subagent started - Agent: \" + .agent_type' --arg timestamp \"$(date '+%Y-%m-%d %H:%M:%S')\" >> ~/.claude/subagent-log.txt"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + $timestamp + \"] Subagent finished - Agent: \" + .agent_id' --arg timestamp \"$(date '+%Y-%m-%d %H:%M:%S')\" >> ~/.claude/subagent-log.txt"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "codex-peer-review@agent-peer-review-marketplace": true
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": false
}
